# Local LLM service. Use the same address that your test.py can call successfully.
LLM_BASE_URL=http://127.0.0.1:1234
LLM_MODEL=Qwen_Qwen3_14B_Q4_K_M
LLM_API_KEY=not-needed
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=180
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_MAX_TOKENS=2048
LLM_CHUNK_CHARS=700
LLM_DISABLE_THINKING=true
LLM_DISABLE_ENV_PROXY=true

# Keep this false unless you specifically want to test LangChain. Direct HTTP is more stable for local OpenAI-compatible servers.
LLM_USE_LANGCHAIN_FIRST=false

# HugeGraph REST
HUGEGRAPH_HOST=127.0.0.1
HUGEGRAPH_PORT=8080
HUGEGRAPH_GRAPHSPACE=DEFAULT
HUGEGRAPH_GRAPH=hugegraph
HUGEGRAPH_TIMEOUT_SECONDS=30
HUGEGRAPH_NODE_LABEL=LogSysKGNodeV5
HUGEGRAPH_EDGE_LABEL=LOGSYS_KG_RELATION_V5
